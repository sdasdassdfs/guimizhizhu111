    {
      "id": "npc_old_nell",
      "name": "老尼尔",
      "description": "值夜者小队的文职人员，序列9窥秘人，负责神秘学资料管理。",
      "location": "值夜者总部资料室",
      "dialogueTree": {
        "startNode": "greeting",
        "nodes": [
          {
            "id": "greeting",
            "speaker": "老尼尔",
            "text": "哦，新来的？看起来你的灵性很不稳定。别担心，每个刚觉醒的人都会这样。",
            "choices": [
              { "id": "ask_about_awakening", "text": "我该怎么办？", "nextNodeId": "advice" },
              { "id": "ask_about_paths", "text": "有哪些途径可以选择？", "nextNodeId": "path_explanation" }
            ]
          },
          {
            "id": "advice",
            "speaker": "老尼尔",
            "text": "首先，深呼吸。非凡特性已经与你融合，现在你需要学习控制它，而不是被它控制。我会教你一些基础冥想技巧。",
            "choices": [
              { "id": "continue", "text": "请继续", "nextNodeId": "meditation_instruction" }
            ]
          }
        ]
      }
    },
    {
      "id": "npc_sharon",
      "name": "莎伦",
      "description": "出现在东区酒吧的神秘女性，实为玫瑰学派的叛逃者，序列6怨魂。",
      "location": "东区地下酒吧",
      "dialogueTree": {
        "startNode": "first_meeting",
        "nodes": [
          {
            "id": "first_meeting",
            "speaker": "莎伦",
            "text": "我注意你很久了。一个刚觉醒的非凡者，却在值夜者的眼皮底下活动...很有趣。",
            "choices": [
              { "id": "who_are_you", "text": "你是谁？", "nextNodeId": "self_intro" },
              { "id": "what_do_you_want", "text": "你想要什么？", "nextNodeId": "proposal" }
            ]
          }
        ]
      }
